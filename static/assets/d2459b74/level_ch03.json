  "level_id": "level_003",
  "chapter": "\u092a\u094d\u0930\u0915\u093e\u0936 \u0915\u093e \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u0925\u093e\u0928",
  "chapter_number": 3,
  "narration": "\u0906\u092a \u0935\u0928 \u0915\u0947 \u0939\u0943\u0926\u092f \u0924\u0915 \u092a\u0939\u0941\u0901\u091a \u091a\u0941\u0915\u0940 \u0939\u0948\u0902, \u091c\u0939\u093e\u0901 \u0938\u0947 \u0905\u0902\u0927\u0947\u0930\u093e \u092b\u0948\u0932 \u0930\u0939\u093e \u0939\u0948\u0964 \u090f\u0915 \u0935\u093f\u0936\u093e\u0932\u0915\u093e\u092f \u091b\u093e\u092f\u093e \u091c\u093e\u0928\u0935\u0930 \u0906\u092a\u0915\u0947 \u0930\u093e\u0938\u094d\u0924\u0947 \u092e\u0947\u0902 \u0916\u0921\u093c\u093e \u0939\u0948, \u091c\u094b \u0935\u0928 \u0915\u0940 \u0938\u093e\u0930\u0940 \u090a\u0930\u094d\u091c\u093e \u0938\u094b\u0916 \u0930\u0939\u093e \u0939\u0948\u0964",
