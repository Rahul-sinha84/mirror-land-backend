  "npcs": [
    {
      "role": "npc",
      "x": 200,
      "y": 780,
      "name": "\u091c\u094d\u091e\u093e\u0928 \u0915\u093e \u0909\u0932\u094d\u0932\u0942",
      "dialogue": [
        {
          "speaker": "\u091c\u094d\u091e\u093e\u0928 \u0915\u093e \u0909\u0932\u094d\u0932\u0942",
          "text": "\u0928\u092e\u0938\u094d\u0924\u0947, \u092c\u0939\u093e\u0926\u0941\u0930 \u0906\u0924\u094d\u092e\u093e\u0964 \u0924\u0941\u092e \u0935\u0928 \u0915\u0947 \u0939\u0943\u0926\u092f \u0924\u0915 \u092a\u0939\u0941\u0901\u091a \u091a\u0941\u0915\u0940 \u0939\u094b\u0964 \u092f\u0939\u093e\u0901 \u0905\u0901\u0927\u0947\u0930\u093e \u0917\u0939\u0930\u093e \u0939\u0948, \u0914\u0930 \u091b\u093e\u092f\u093e \u091c\u093e\u0928\u0935\u0930 \u0935\u0928 \u0915\u0940 \u0938\u093e\u0930\u0940 \u090a\u0930\u094d\u091c\u093e \u0938\u094b\u0916 \u0930\u0939\u093e \u0939\u0948\u0964 \u0924\u0941\u092e\u094d\u0939\u0947\u0902 \u0905\u092a\u0928\u0940 \u0930\u094b\u0936\u0928\u0940 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u093e \u0939\u094b\u0917\u093e\u0964"
        },
        {
          "speaker": "\u091c\u094d\u091e\u093e\u0928 \u0915\u093e \u0909\u0932\u094d\u0932\u0942",
          "text": "\u0938\u093e\u0935\u0927\u093e\u0928 \u0930\u0939\u0928\u093e, \u0915\u094d\u092f\u094b\u0902\u0915\u093f \u0905\u0901\u0927\u0947\u0930\u0947 \u092e\u0947\u0902 \u0926\u0947\u0916\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0924\u0941\u092e\u094d\u0939\u093e\u0930\u0940 \u091f\u0949\u0930\u094d\u091a \u0915\u0940 \u0930\u094b\u0936\u0928\u0940 \u0939\u0940 \u090f\u0915\u092e\u093e\u0924\u094d\u0930 \u0938\u0939\u093e\u0930\u093e \u0939\u0948\u0964 \u0905\u092a\u0928\u0940 \u0932\u0947\u091c\u0930 \u0936\u0949\u091f \u0915\u094d\u0937\u092e\u0924\u093e \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947 \u091b\u093e\u092f\u093e \u091c\u093e\u0928\u0935\u0930 \u0914\u0930 \u0909\u0938\u0915\u0947 minions \u0915\u094b \u0939\u0930\u093e\u0913 \u0914\u0930 \u0935\u0928 \u0915\u094b \u092c\u091a\u093e\u0913!"
        }
      ]
    }
  ],
