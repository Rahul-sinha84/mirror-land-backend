  "mission": {
    "type": "kill_all",
    "description": "\u0935\u0928 \u0915\u094b \u0909\u0938\u0915\u0947 \u0905\u092d\u093f\u0936\u093e\u092a \u0938\u0947 \u092e\u0941\u0915\u094d\u0924 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u091b\u093e\u092f\u093e\u0926\u093e\u0930 \u091c\u093e\u0928\u0935\u0930 \u0914\u0930 \u0909\u0938\u0915\u0947 minions \u0915\u094b \u0939\u0930\u093e\u090f\u0901!",
    "target_count": 10,
    "success_text": "\u0906\u092a\u0928\u0947 \u091b\u093e\u092f\u093e \u091c\u093e\u0928\u0935\u0930 \u0915\u094b \u0939\u0930\u093e \u0926\u093f\u092f\u093e! \u0935\u0928 \u092b\u093f\u0930 \u0938\u0947 \u091a\u092e\u0915 \u0909\u0920\u093e \u0914\u0930 \u091c\u0940\u0935\u0928 \u0938\u0947 \u092d\u0930 \u0917\u092f\u093e!",
    "fail_text": "\u091b\u093e\u092f\u093e \u091c\u093e\u0928\u0935\u0930 \u092c\u0939\u0941\u0924 \u0936\u0915\u094d\u0924\u093f\u0936\u093e\u0932\u0940 \u0925\u093e \u0914\u0930 \u0909\u0938\u0928\u0947 \u0906\u092a\u0915\u094b \u0939\u0930\u093e \u0926\u093f\u092f\u093e\u0964 \u0935\u0928 \u0939\u092e\u0947\u0936\u093e \u0915\u0947 \u0932\u093f\u090f \u0905\u0902\u0927\u0947\u0930\u0947 \u092e\u0947\u0902 \u0916\u094b \u0917\u092f\u093e\u0964 \u092b\u093f\u0930 \u0938\u0947 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902!"
