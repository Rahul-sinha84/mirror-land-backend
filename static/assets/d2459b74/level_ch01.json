  "chapter": "\u0936\u093e\u0939\u0940 \u092c\u0917\u0940\u091a\u0947 \u0915\u093e \u0930\u0939\u0938\u094d\u092f",
  "chapter_number": 1,
  "narration": "\u0906\u092a \u0936\u093e\u0939\u0940 \u092c\u0917\u0940\u091a\u0947 \u092e\u0947\u0902 \u091f\u0939\u0932 \u0930\u0939\u0940 \u0939\u0948\u0902, \u091c\u0939\u093e\u0901 \u0938\u0926\u093f\u092f\u094b\u0902 \u092a\u0941\u0930\u093e\u0928\u0947 \u092a\u0947\u0921\u093c \u0914\u0930 \u091a\u092e\u0915\u0924\u0947 \u092b\u0942\u0932 \u0906\u092a\u0915\u093e \u092e\u0928 \u092e\u094b\u0939 \u0932\u0947\u0924\u0947 \u0939\u0948\u0902\u0964 \u0905\u091a\u093e\u0928\u0915, \u0906\u092a\u0915\u094b \u090f\u0915 \u0930\u0939\u0938\u094d\u092f\u092e\u092f\u0940 \u091a\u092e\u0915 \u0926\u093f\u0916\u0924\u0940 \u0939\u0948 \u091c\u094b \u090f\u0915 \u091b\u093f\u092a\u0947 \u0939\u0941\u090f \u0930\u093e\u0938\u094d\u0924\u0947 \u0915\u0940 \u0913\u0930 \u0907\u0936\u093e\u0930\u093e \u0915\u0930 \u0930\u0939\u0940 \u0939\u0948\u0964",
