    "success_text": "\u0906\u092a\u0928\u0947 \u091c\u093e\u0926\u0941\u0908 \u092b\u0942\u0932 \u0922\u0942\u0902\u0922 \u0932\u093f\u092f\u093e \u0914\u0930 \u092a\u094b\u0930\u094d\u091f\u0932 \u091a\u092e\u0915\u0928\u0947 \u0932\u0917\u093e! \u0906\u092a \u090f\u0915 \u0928\u0908 \u0926\u0941\u0928\u093f\u092f\u093e \u092e\u0947\u0902 \u092a\u094d\u0930\u0935\u0947\u0936 \u0915\u0930\u0924\u0940 \u0939\u0948\u0902!",
    "fail_text": "\u0906\u092a \u092b\u0942\u0932 \u0928\u0939\u0940\u0902 \u0922\u0942\u0902\u0922 \u092a\u093e\u0908\u0902 \u0914\u0930 \u092a\u094b\u0930\u094d\u091f\u0932 \u0928\u093f\u0937\u094d\u0915\u094d\u0930\u093f\u092f \u0939\u094b \u0917\u092f\u093e\u0964 \u0906\u092a\u0915\u094b \u092b\u093f\u0930 \u0938\u0947 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0928\u093e \u0939\u094b\u0917\u093e!"
